# CryptoStream — local environment.
# Copy to `.env` and adjust. Never commit `.env`.

# ---- Postgres (medallion + airflow metadata share one instance, separate DBs)
POSTGRES_USER=cryptostream
POSTGRES_PASSWORD=cryptostream
POSTGRES_DB=cryptostream
DATABASE_URL=postgresql://cryptostream:cryptostream@postgres:5432/cryptostream

# ---- Kafka
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC_PRICES=prices
KAFKA_TOPIC_DLQ=prices.dlq

# ---- Source (FreeCryptoAPI WebSocket; user provides their own key)
FREECRYPTO_WS_URL=wss://api.freecryptoapi.com/ws
FREECRYPTO_API_KEY=changeme
WATCHLIST=BTCUSD,ETHUSD,SOLUSD
# `action_symbols` (default) or `type_channels` — depends on FreeCryptoAPI's protocol
FREECRYPTO_SUBSCRIBE_FMT=action_symbols

# ---- Spark
SPARK_CHECKPOINT_DIR=/checkpoints/bronze

# ---- API (Module 7)
GOLD_SCHEMA=gold
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
DB_POOL_MIN=1
DB_POOL_MAX=8

# ---- Dashboard (Module 7)
# VITE_API_BASE is baked into the JS bundle at build time.
VITE_API_BASE=http://localhost:8000
VITE_WATCHLIST=BTCUSD,ETHUSD,SOLUSD

# ---- Airflow (Module 1 placeholders; replaced properly in Module 6)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://cryptostream:cryptostream@postgres:5432/airflow

# Bronze retention window in days (consumed by retention_dag via Airflow Variable).
BRONZE_RETENTION_DAYS=7
